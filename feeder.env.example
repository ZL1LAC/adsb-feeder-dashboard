# Feeder dashboard configuration (copy to feeder.env and edit)
REPO_ROOT=/home/server/adsb-feeder-dashboard
FEEDER_USER=server
FEEDER_MUNINN_ROOT=/home/server/adsb-feeder-dashboard/muninn
FEEDER_AIRCRAFT_JSON=/run/readsb/aircraft.json
FEEDER_LOCATION_FILE=/etc/default/airplanes
FEEDER_READSB_DEFAULT=/etc/default/readsb
FEEDER_STATS_JSON=/run/readsb/stats.json
TAR1090_PREFIX=/tar1090
FEED_PROFILE=airplanes

# adsb.im profile (use with ./scripts/install.sh --profile adsbim):
# FEED_PROFILE=adsbim
# FEEDER_LOCATION_FILE=/opt/adsb/config/.env

# Gotify alerts (optional — leave GOTIFY_APP_TOKEN empty to disable)
GOTIFY_URL=
GOTIFY_APP_TOKEN=
ALERT_OVERHEAD_KM=5
ALERT_OVERHEAD_FT=3000
ALERT_SQUAWK_ENABLED=true
ALERT_SQUAWK_EMERGENCY=true
ALERT_SQUAWK_EXTRA=

# WDGoWars uploads (optional — enable in Settings after saving API key)
WDGWARS_ENABLED=false
WDGWARS_UPLOAD_INTERVAL_MIN=5

# Split stack (Pi = decode only, Docker = dashboard + alerts)
# On Pi: FEEDER_DEPLOY_MODE is not set; run scripts/install-pi-decode-only.sh
# On Docker: set FEEDER_DEPLOY_MODE=split and PI_AGENT_* (see docker/.env.example)
# FEEDER_DEPLOY_MODE=split
# PI_AGENT_URL=http://192.168.1.50:8780
# PI_AGENT_TOKEN=
# PI_AGENT_PORT=8780

# Split-stack Docker host — copy to docker/.env and edit
# Pi decode host (lighttpd + tar1090 on port 80)
PI_HOST=192.168.1.50

# Pi agent (install with scripts/install-pi-agent.sh on the Pi)
PI_AGENT_URL=http://192.168.1.50:8780
PI_AGENT_TOKEN=change-me-to-a-long-random-string

# Dashboard URL port on this Docker machine
DASHBOARD_PORT=8091

# Gotify (can be this host or external e.g. https://alerts.lacdh.live)
GOTIFY_URL=https://alerts.lacdh.live
GOTIFY_APP_TOKEN=

# WDGoWars — configure API key in Settings after first boot
WDGWARS_ENABLED=true
WDGWARS_UPLOAD_INTERVAL_MIN=5
